# Neon PostgreSQL (free tier) — create at https://neon.tech or via Vercel Marketplace
# Pooled connection — app runtime (serverless / Next.js). Neon/Vercel name: DATABASE_URL
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection — Prisma migrations. Neon/Vercel name: DATABASE_URL_UNPOOLED
# Copy unpooled URL here as DIRECT_URL (Prisma schema uses this name)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Set to true on Vercel (also set via auth.config trustHost)
AUTH_TRUST_HOST="true"

# Public site URL (sitemap, JSON-LD, Open Graph)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudinary — recommended for production image CDN (auto format, transforms)
# Sign up free: https://cloudinary.com/users/register/free
# Then copy from https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional: expose cloud name to client for URL helpers
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Vercel Blob — auto-injected when you connect a Blob store (recommended on Vercel)
# BLOB_READ_WRITE_TOKEN=""

# Cron — scheduled article publishing (Vercel Cron / external scheduler)
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Supabase (optional — for auth + RLS database on Supabase Cloud)
# Dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# Dashboard → Account → Access Tokens (for CLI / GitHub Actions)
SUPABASE_ACCESS_TOKEN=""
# Dashboard → Project Settings → General → Reference ID
SUPABASE_PROJECT_REF=""
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:newsroom@orbitsphere.ng"

# Resend — transactional email (password reset, newsletter welcome, premium)
# Sign up at https://resend.com — verify your sending domain for production
RESEND_API_KEY=""
EMAIL_FROM="OrbitSphere <newsroom@orbitsphere.ng>"

# Paystack — premium subscriptions (https://paystack.com)
# Use test keys for development: sk_test_… / pk_test_…
PAYSTACK_SECRET_KEY=""
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
