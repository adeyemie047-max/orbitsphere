// OrbitSphere — database schema per PRD §6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  editor
  journalist
  reader

  @@map("user_role")
}

enum ArticleStatus {
  draft
  scheduled
  published
  archived

  @@map("article_status")
}

enum NotificationType {
  breaking
  reply
  recommendation

  @@map("notification_type")
}

enum CitizenSubmissionStatus {
  pending
  reviewed
  approved
  rejected

  @@map("citizen_submission_status")
}

enum AdPlacement {
  banner
  sidebar
  inline
  footer

  @@map("ad_placement")
}

enum PremiumPlan {
  monthly
  annual

  @@map("premium_plan")
}

enum PremiumStatus {
  pending
  active
  cancelled
  expired

  @@map("premium_status")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified") @db.Timestamp(6)
  passwordHash  String?   @map("password_hash")
  fullName      String?   @map("full_name") @db.VarChar(255)
  username      String?   @unique @db.VarChar(100)
  role          UserRole  @default(reader)
  avatarUrl     String?   @map("avatar_url")
  bio           String?
  isVerified    Boolean   @default(false) @map("is_verified")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  accounts            Account[]
  sessions            Session[]
  articles            Article[]
  comments            Comment[]
  bookmarks           Bookmark[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  categoryFollows     UserCategoryFollow[]
  pollVotes           PollVote[]
  pushSubscriptions   PushSubscription[]
  liveBlogEntries     LiveBlogEntry[]
  premiumSubscription PremiumSubscription?

  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamp(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expires   DateTime @db.Timestamp(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  color       String?   @db.VarChar(20)
  icon        String?   @db.VarChar(50)
  sortOrder   Int?      @map("sort_order")

  articles Article[]
  followers UserCategoryFollow[]

  @@map("categories")
}

model Article {
  id              String        @id @default(uuid()) @db.Uuid
  title           String        @db.VarChar(500)
  slug            String        @unique @db.VarChar(500)
  excerpt         String?
  body            String?
  featuredImage   String?       @map("featured_image")
  authorId        String        @map("author_id") @db.Uuid
  categoryId      String        @map("category_id") @db.Uuid
  status          ArticleStatus
  isBreaking      Boolean       @default(false) @map("is_breaking")
  isFeatured      Boolean       @default(false) @map("is_featured")
  isInvestigative Boolean       @default(false) @map("is_investigative")
  isLiveBlog      Boolean       @default(false) @map("is_live_blog")
  submittedForReview Boolean    @default(false) @map("submitted_for_review")
  viewsCount      Int           @default(0) @map("views_count")
  readTime        Int?          @map("read_time")
  publishedAt     DateTime?     @map("published_at") @db.Timestamp(6)
  scheduledAt     DateTime?     @map("scheduled_at") @db.Timestamp(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)

  author      User         @relation(fields: [authorId], references: [id])
  category    Category     @relation(fields: [categoryId], references: [id])
  comments    Comment[]
  bookmarks   Bookmark[]
  articleTags ArticleTag[]
  polls       Poll[]
  liveBlogEntries LiveBlogEntry[]

  @@map("articles")
}

model Comment {
  id          String   @id @default(uuid()) @db.Uuid
  articleId   String   @map("article_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  parentId    String?  @map("parent_id") @db.Uuid
  body        String?
  isApproved  Boolean  @default(false) @map("is_approved")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  article  Article  @relation(fields: [articleId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  parent   Comment? @relation("CommentThread", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentThread")

  @@map("comments")
}

model Bookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  articleId String   @map("article_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user    User    @relation(fields: [userId], references: [id])
  article Article @relation(fields: [articleId], references: [id])

  @@unique([userId, articleId])
  @@map("bookmarks")
}

model Tag {
  id   String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(100)
  slug String @unique @db.VarChar(100)

  articleTags ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  articleId String @map("article_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  article Article @relation(fields: [articleId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
  @@map("article_tags")
}

model Newsletter {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  subscribedAt DateTime @default(now()) @map("subscribed_at") @db.Timestamp(6)

  @@map("newsletters")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  message   String?
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Poll {
  id        String    @id @default(uuid()) @db.Uuid
  question  String?
  articleId String?   @map("article_id") @db.Uuid
  endsAt    DateTime? @map("ends_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  article Article?   @relation(fields: [articleId], references: [id])
  options PollOption[]
  votes   PollVote[]

  @@map("polls")
}

model PollOption {
  id         String @id @default(uuid()) @db.Uuid
  pollId     String @map("poll_id") @db.Uuid
  optionText String? @map("option_text") @db.VarChar(255)
  voteCount  Int    @default(0) @map("vote_count")

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(uuid()) @db.Uuid
  pollId    String   @map("poll_id") @db.Uuid
  optionId  String   @map("option_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  voterKey  String   @map("voter_key") @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User?      @relation(fields: [userId], references: [id])

  @@unique([pollId, voterKey])
  @@map("poll_votes")
}

model UserCategoryFollow {
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("user_category_follows")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model LiveBlogEntry {
  id          String   @id @default(uuid()) @db.Uuid
  articleId   String   @map("article_id") @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  body        String
  isPinned    Boolean  @default(false) @map("is_pinned")
  publishedAt DateTime @default(now()) @map("published_at") @db.Timestamp(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@map("live_blog_entries")
}

model CitizenSubmission {
  id            String                  @id @default(uuid()) @db.Uuid
  submitterName String?                 @map("submitter_name") @db.VarChar(255)
  email         String?                 @db.VarChar(255)
  title         String?                 @db.VarChar(500)
  body          String?
  mediaUrl      String?                 @map("media_url")
  status        CitizenSubmissionStatus
  submittedAt   DateTime                @default(now()) @map("submitted_at") @db.Timestamp(6)

  @@map("citizen_submissions")
}

model Advertisement {
  id          String      @id @default(uuid()) @db.Uuid
  title       String?     @db.VarChar(255)
  imageUrl    String?     @map("image_url")
  targetUrl   String?     @map("target_url")
  placement   AdPlacement
  isActive    Boolean     @map("is_active")
  startsAt    DateTime?   @map("starts_at") @db.Timestamp(6)
  endsAt      DateTime?   @map("ends_at") @db.Timestamp(6)
  impressions Int         @default(0)
  clicks      Int         @default(0)

  @@map("advertisements")
}

model AdvertiseInquiry {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  company   String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  budget    String?  @db.VarChar(100)
  message   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("advertise_inquiries")
}

model PremiumSubscription {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @unique @map("user_id") @db.Uuid
  plan              PremiumPlan
  status            PremiumStatus @default(pending)
  paystackReference String?       @unique @map("paystack_reference") @db.VarChar(255)
  amountKobo        Int           @map("amount_kobo")
  currentPeriodEnd  DateTime?     @map("current_period_end") @db.Timestamp(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("premium_subscriptions")
}

model SiteBranding {
  id                    String   @id @default("default")
  siteNamePrimary       String   @default("Orbit") @map("site_name_primary") @db.VarChar(100)
  siteNameAccent        String   @default("Sphere") @map("site_name_accent") @db.VarChar(100)
  siteTagline           String   @default("Independent · African") @map("site_tagline") @db.VarChar(255)
  mastheadLocations     String   @default("Lagos · Abuja · London") @map("masthead_locations") @db.VarChar(255)
  siteDescription       String   @map("site_description")
  footerDescription     String   @map("footer_description")
  newsletterHeading     String   @map("newsletter_heading") @db.VarChar(255)
  newsletterDescription String   @map("newsletter_description")
  newsletterTagline     String   @map("newsletter_tagline") @db.VarChar(255)
  copyrightName         String   @default("OrbitSphere Media Limited") @map("copyright_name") @db.VarChar(255)
  copyrightYear         Int      @default(2026) @map("copyright_year")
  logoUrl               String?  @map("logo_url")
  faviconUrl            String?  @map("favicon_url")
  accentColor           String   @default("#C8FF00") @map("accent_color") @db.VarChar(20)
  inkColor              String   @default("#0A0A0A") @map("ink_color") @db.VarChar(20)
  paperColor            String   @default("#F5F5F0") @map("paper_color") @db.VarChar(20)
  seoTitle              String   @map("seo_title") @db.VarChar(255)
  seoDescription        String   @map("seo_description")
  ogImageUrl            String?  @map("og_image_url")
  twitterUrl            String?  @map("twitter_url")
  facebookUrl           String?  @map("facebook_url")
  linkedinUrl           String?  @map("linkedin_url")
  youtubeUrl            String?  @map("youtube_url")
  instagramUrl          String?  @map("instagram_url")
  contactEmail          String?  @map("contact_email") @db.VarChar(255)
  contactPhone          String?  @map("contact_phone") @db.VarChar(50)
  contactAddress        String?  @map("contact_address")
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("site_branding")
}
