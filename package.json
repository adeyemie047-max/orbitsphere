{
  "name": "orbitsphere",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "node scripts/clean-dev.mjs",
    "build": "prisma generate && next build && next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:setup": "npm run db:push && npm run db:seed",
    "db:supabase": "powershell -ExecutionPolicy Bypass -File scripts/run-supabase-migration.ps1",
    "db:supabase-cloud": "powershell -ExecutionPolicy Bypass -File scripts/run-supabase-cloud.ps1",
    "postgres:start": "powershell -ExecutionPolicy Bypass -File scripts/start-postgres.ps1",
    "postgres:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-postgres.ps1",
    "postgres:install": "powershell -ExecutionPolicy Bypass -File scripts/install-postgres.ps1",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "next": "^15.3.0",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.4",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "next-sitemap": "^4.2.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
